##################################################
# Development image: app + tests + lint tooling
# Used to run nosetests, flake8, pylint and the
# live service locally on machines without Python 3.9.
##################################################
FROM python:3.9-slim

WORKDIR /app

COPY requirements.txt .
RUN python -m pip install --upgrade pip wheel && \
    pip install --no-cache-dir -r requirements.txt

# Copy everything (service + tests + config)
COPY . .

EXPOSE 8080
CMD ["nosetests"]
